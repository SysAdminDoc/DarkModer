{
    "description": "Site-specific fixes for Filter and Filter+ modes",
    "version": "1.0.0",
    "fixes": {
        "default": {
            "invert": [
                "img",
                "video",
                "picture",
                "canvas",
                "iframe",
                "embed",
                "object",
                "svg image",
                "[style*=\"background-image\"]:not([style*=\"gradient\"])",
                ".emoji",
                "[class*=\"emoji\"]",
                "[role=\"img\"]"
